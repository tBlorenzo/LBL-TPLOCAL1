@model TPLOCAL1.Models.Avis

<head>
    <title>Validation</title>
    <link rel="stylesheet" href="~/resources/Index.css" />
</head>


<body>
    <header>
        <img src="~/resources/GroupeHN.png " class="image " alt="GroupeHN " />
        <h1>Page de validation</h1>
    </header>

    
    <nav>
        <ul>
            <li><a href="/Home/Index/">Accueil</a></li>
            <li><a href="/Home/Index/OpinionList">List avis</a></li>
        </ul>
    </nav>

    <section>
        <h4 style="text-align: left;">Votre formulaire a bien été pris en compte</h4>

        <table class="form-table">
            <caption class="table-title">Informations personnelles</caption>
            <tr>
                <td>Nom</td>
                <td>@Model.Nom</td>
            </tr>
            <tr>
                <td>Prénom</td>
                <td>@Model.Prenom</td>
            </tr>
            <tr>
                <td>Sexe</td>
                <td>@Model.Genre</td>
            </tr>
            <tr>
                <td>Adresse</td>
                <td>@Model.Adresse</td>
            </tr>
            <tr>
                <td>Code Postal</td>
                <td>@Model.CodePostal</td>
            </tr>
            <tr>
                <td>Ville</td>
                <td>@Model.Ville</td>
            </tr>
            <tr>
                <td>Email</td>
                <td>@Model.Email</td>
            </tr>
        </table>

        <table class="form-table">
            <caption class="table-title">Informations sur la formation</caption>
            <tr>
                <td>Date de début</td>
                <td>@Model.DateDebut.ToString("dd/MM/yyyy")</td>
            </tr>
            <tr>
                <td>Formation suivie</td>
                <td>@Model.Cours</td>
            </tr>
        </table>

        <table class="form-table">
            <caption class="table-title">Avis sur la formation</caption>
            <tr>
                <td>Formation Cobol</td>
                <td>@Model.Cobol</td>
            </tr>
            <tr>
                <td>Formation C#</td>
                <td>@Model.CSharp</td>
            </tr>
        </table>
    </section>
</body>
 