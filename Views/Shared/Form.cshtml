@model TPLOCAL1.Models.Avis
@{
    Layout = "_Menu";
}

@{
    ViewBag.TitleHeader = "Formulaire";
}

<form asp-action="ValidationForm" method="post">
      <table class="form-table">
          <caption class="table-title">Informations personnelles</caption>          <tr>
              <td>Nom</td>
              <td>
                  <input asp-for="Nom" placeholder="Votre nom" />
                  <span asp-validation-for="Nom"></span>
              </td>
          </tr>          <tr>
              <td>Prénom</td>
              <td>
                  <input asp-for="Prenom" placeholder="Votre prénom" />
                  <span asp-validation-for="Prenom"></span>
              </td>
          </tr>          <tr>
              <td>Genre</td>
              <td>
                  <select asp-for="Genre">
                      <option value="">Sélectionnez un sexe</option>
                      <option>Homme</option>
                      <option>Femme</option>
                      <option>Autre</option>
                  </select>
                  <span asp-validation-for="Genre"></span>
              </td>
          </tr>          <tr>
              <td>Adresse</td>
              <td>
                  <input asp-for="Adresse" />
                  <span asp-validation-for="Adresse"></span>
              </td>
          </tr>          <tr>
              <td>Code postal</td>
              <td>
                  <input asp-for="CodePostal" placeholder="Exemple : 94700" />
                  <span asp-validation-for="CodePostal"></span>
              </td>
          </tr>          <tr>
              <td>Ville</td>
              <td>
                  <input asp-for="Ville" />
                  <span asp-validation-for="Ville"></span>
              </td>
          </tr>          <tr>
              <td>Email</td>
              <td>
                  <input asp-for="Email" placeholder="votremail@server.domain" />
                  <span asp-validation-for="Email"></span>
              </td>
          </tr>
      </table>      <table class="form-table">
          <caption class="table-title">Informations formation suivie</caption>          <tr>
              <td> Date de début de la formation</td>
              <td>
                  <input asp-for="DateDebut" />
                  <span asp-validation-for="DateDebut"></span>
              </td>
          </tr>          <tr>
              <td>Type de formation</td>
              <td>
                  <select asp-for="Cours">
                      <option value="">Sélectionnez une formation</option>
                      <option>Formation Cobol</option>
                      <option>Formation par objet</option>
                      <option>Formation à double compétence</option>
                  </select>
                  <span asp-validation-for="Cours"></span>
              </td>
          </tr>
      </table>      <table class="form-table">
          <caption class="table-title">Avis sur la formation</caption>          <tr>
              <td>Cobol Formation</td>
              <td>
                  <input asp-for="Cobol" placeholder="Laissez votre avis" />
                  <span asp-validation-for="Cobol"></span>
              </td>
          </tr>          <tr>
              <td>C# Formation</td>
              <td>
                  <input asp-for="CSharp" placeholder="Laissez votre avis" />
                  <span asp-validation-for="CSharp"></span>
              </td>
          </tr>
      </table>      
      <br />
      <button type="submit">Validation</button>
</form>

